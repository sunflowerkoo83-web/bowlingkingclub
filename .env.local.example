# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"에서 발급받은 JSON의 값을 채워주세요.
# 이 파일을 .env.local로 복사한 뒤 실제 값을 입력하세요. (.env.local은 git에 커밋되지 않습니다)

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# 관리자 페이지(/admin) 로그인 비밀번호
ADMIN_PASSWORD=
# 세션 쿠키 서명용 랜덤 문자열. 터미널에서 `openssl rand -hex 32`로 생성 권장
ADMIN_SESSION_SECRET=

# Vercel 대시보드 > Storage > Blob 스토어 생성/연결 시 자동 발급됨.
# 로컬 개발용으로는 `vercel env pull .env.local`로 받아오거나 대시보드에서 직접 복사
BLOB_READ_WRITE_TOKEN=
